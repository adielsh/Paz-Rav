# ---- Market data vendor ----
POLYGON_API_KEY=your-polygon-key-here

# ---- Datastores (match docker-compose.yml) ----
DATABASE_URL=postgresql://paz:paz@localhost:5432/pazrav
REDIS_URL=redis://localhost:6379/0

# ---- AI layer (Phase 2) ----
ANTHROPIC_API_KEY=your-anthropic-key-here
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Runtime ----
PAZ_ENV=local
LOG_LEVEL=INFO
# Comma-separated underlyings to track
UNDERLYINGS=SPY,QQQ,IWM,SPX,RUT
# Max concurrent LLM agent calls (the Semaphore(k) from the concurrency model)
AGENT_CONCURRENCY=4
